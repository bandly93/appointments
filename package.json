{
  "name": "appointment-simulator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev:all": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "pg": "^8.22.0"
  }
}
